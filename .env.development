# 后端环境变量配置

# 允许的CORS来源（用逗号分隔多个域名）
# 开发环境示例
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# 安全配置
JWT_SECRET_KEY=change_this_to_a_secure_random_string_in_production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 第三方服务 (可选，留空则使用数据库配置)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DEEPSEEK_API_KEY=
