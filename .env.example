# 数据库配置
DATABASE_URL=postgresql://newsbot:your_password@localhost:5432/ainews

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Telegram配置
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHANNEL_ID=@your_channel  # 或 -100xxxxxxxxx

# 爬虫配置
SCRAPE_INTERVAL_HOURS=2
PUSH_TIMES=09:00,15:00,21:00

# AI配置
AI_SIMILARITY_THRESHOLD=0.85  # 去重相似度阈值
AI_MIN_SCORE=50               # 最低推送评分

# Web配置（后端）
PORT=3000
ADMIN_PASSWORD=your_admin_password
